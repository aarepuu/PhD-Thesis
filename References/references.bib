	year = {2002},
	keywords = {ALTRUISM HUMAN CAPITAL INTRINSIC MOTIVATION MOTIVATIONS OPEN-SOURCE SOFTWARE SOFTWARE DEVELOPMENT},
	pages = {25--39}
