	shorttitle = {Beyond {Personal} {Informatics}},
	url = {http://dl.acm.org/citation.cfm?doid=2702613.2702632},
	doi = {10.1145/2702613.2702632},
	abstract = {In this paper I outline a potential context whereby personal informatics tools could be used to reveal organizational practice. Specifically, I consider whether some of the common issues for home care workers in the UK could be highlighted by self-tracking their working day. Workers could use such data for individual purposes (e.g. contestation of pay and/or conditions). It could also have a wider social or political purpose if it were to be used by those lobbying policy-makers, employers and care commissioners on behalf of workers (e.g. trade unions).},
