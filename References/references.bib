	issn = {1097-4571},
	shorttitle = {{gIBIS}},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/%28SICI%291097-4571%28198905%2940%3A3%3C200%3A%3AAID-ASI11%3E3.0.CO%3B2-U},
