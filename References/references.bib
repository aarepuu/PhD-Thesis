@article{shaer_surveillance_nodate,
	title = {Surveillance {Considerations} {Concerning} {Assistive} {Devices} for {People} with {Visual} {Impairments}},
	abstract = {The use of cameras to assist persons with visual impairments is rapidly becoming realizable. However, the surveillance implications of cameras as assistive devices present unintended eﬀects which must be considered during the design of an assistive system. During a recent study of persons with visual impairments, a signiﬁcant number of those persons in the study desired a forensics capability to accompany their camera so that they can have a record of harmful events that they could share with either a trusted agent or law enforcement. Incorporating a forensics feature into an assistive device presents an opportunity for social good as well as potential harm in the form of surveillance.},
	language = {en},
