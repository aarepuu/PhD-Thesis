@article{mortier_challenges_nodate,
	title = {Challenges \& {Opportunities} in {Human}-{Data} {Interaction}},
	abstract = {As personal data are increasingly collected, analysed, and traded, we introduce the topic of Human-Data Interaction (HDI) to engage users with their data. HDI is inherently inter-disciplinary, encapsulating elements not only of traditional computer science such as data processing, systems design, visualisation and interaction design, but also of law, psychology, behavioural economics, and sociology. We outline HDI’s motivation, its privacy and ethical challenges, and the opportunities it presents.},
	language = {en},
	author = {Mortier, Richard and Haddadi, Hamed and Henderson, Tristan and McAuley, Derek and Crowcroft, Jon},
	pages = {3}
}

@article{haddadi_human-data_nodate,
	title = {Human-data interaction},
	abstract = {The time has come to recognise the emerging topic of Human-Data Interaction (HDI). It arises from the need, both ethical and practical, to engage users to a much greater degree with the collection, analysis, and trade of their personal data, in addition to providing them with an intuitive feedback mechanism. HDI is inherently inter-disciplinary, encapsulating elements not only of traditional computer science ranging across data processing, systems design, visualisation and interaction design, but also of law, psychology, behavioural economics, and sociology. In this short paper we elaborate the motivation for studying the nature and dynamics of HDI, and we give some thought to challenges and opportunities in developing approaches to this novel discipline.},
	language = {en},
	author = {Haddadi, Hamed and Mortier, Richard and McAuley, Derek and Crowcroft, Jon},
	pages = {9}
}

