@article{noauthor_using_nodate,
	title = {Using {System} {Dynamics} to {Construct} {Design} {Theory} for {Community} {Information} {Systems} {\textbar} {The} {Journal} of {Community} {Informatics}},
	url = {http://ci-journal.net/index.php/ciej/article/view/319},
	abstract = {Virtual communities are complex and evolving socio-technical systems. The design of community information systems requires much theoretical research to solve design problems. A design theory is a prescriptive theory which helps optimize design methods. Community IS design theory is still very young and fragmented, however. In the design theory development process, a mix of theory components is used to solve novel problems or existing problems more effectively and efficiently. We present a meta-model of IS development which focuses on the role of theory in IS design. We show how simulation via system dynamics could play an important role in a more systematic development of design theory for community information systems.},
	language = {en-US},
	urldate = {2020-03-05}
}

