	author = {Le Dantec, Christopher A. and Edwards, W. Keith},
	year = {2010},
	note = {event-place: Atlanta, Georgia, USA},
	keywords = {cooperative work, field study, organizational bound- aries, public sector},
	pages = {113--122}
}

@inproceedings{voida_bridging_2012,
