	abstract = {The rich and intimate information available to continuously listening devices could have an impact on our interactions with technology, and each other, in the personal, public, and political spheres. As ‘listening services’ are deployed, the public will have to come to terms not only with their use and potential benefits, but also with their social, professional, and civic implications. We plan to prototype listening services to push technology development and to inform discussion on the social implications of audio surveillance services.},
	language = {en},
