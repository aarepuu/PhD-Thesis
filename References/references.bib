	title = {Modeling of epidemic spread by social interactions},
	doi = {10.1109/RTEICT.2016.7808045},
	abstract = {Epidemic diseases spread is one of the major problems related to our health and it increases with increase in our social involvement. To examine the behavior of such epidemic contact network in a society, various mathematical epidemic models had been proposed earlier. One of them is the basic SIR( susceptible-infected-recovery) model. Which was not that much effective one, as various assumptions are considered in this model which are not acceptable in real life. Here, by considering the real heterogeneous contact network among people in society rather than homogeneous one as in standard SIR model, proposed an improved SIR model called as ISIR model. The model uses four different immunization strategies which are, random set (RS), dominating set (DS), critical set (CS) and high degree set (HS) based on the different contacts among different people.},
	booktitle = {2016 {IEEE} {International} {Conference} on {Recent} {Trends} in {Electronics}, {Information} {Communication} {Technology} ({RTEICT})},
	author = {Thakare, P. R. and Mathurkar, S. S.},
	month = may,
	year = {2016},
	keywords = {CS, Computational modeling, DS, Diseases, Epidemics, HS, ISIR model, Immune system, Immunization strategies, Mathematical model, RS, Social contact network, Sociology, Standards, Statistics, critical set, diseases, dominating set, epidemic contact network, epidemic diseases, epidemic spread modeling, high degree set, immunization strategies, improved SIR model, mathematical epidemic models, random set, set theory, social interactions, susceptible-infected-recovery model},
	pages = {1320--1324}
}

@article{monroy-hernandez_new_2013,
