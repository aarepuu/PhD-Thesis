@inproceedings{dow_thoughtcloud:_2016,
	address = {Santa Clara, California, USA},
	title = {{ThoughtCloud}: {Exploring} the {Role} of {Feedback} {Technologies} in {Care} {Organisations}},
	isbn = {978-1-4503-3362-7},
	shorttitle = {{ThoughtCloud}},
	url = {http://dl.acm.org/citation.cfm?doid=2858036.2858105},
