}

@inproceedings{asad_illegitimate_2015,
	address = {New York, NY, USA},
	series = {{CSCW} '15},
	title = {Illegitimate {Civic} {Participation}: {Supporting} {Community} {Activists} on the {Ground}},
	isbn = {978-1-4503-2922-4},
	shorttitle = {Illegitimate {Civic} {Participation}},
